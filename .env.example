# ─── Server ───────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ─── Database (Postgres) ──────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=app_db
DB_USER=postgres
DB_PASSWORD=postgres

# ─── CORS ─────────────────────────────────────────────
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# ─── Auth (JWT) ───────────────────────────────────────
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
COOKIE_SECRET=change-me-too

# ─── Rate Limiting ────────────────────────────────────
RATE_LIMITING_ENABLED=false
REDIS_URL=

# ─── API Contract ─────────────────────────────────────
API_CONTRACT_V2_ENABLED=false
